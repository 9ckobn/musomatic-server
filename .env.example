# ─── Server ──────────────────────────────────────────────────────
# Directory where FLAC files are stored (shared with Navidrome)
MUSIC_DIR=/root/music

# slskd (Soulseek client) connection
SLSKD_URL=http://slskd:5030
SLSKD_KEY=your-slskd-api-key-here

# SOCKS/HTTP proxy for Tidal API (leave empty if not needed)
PROXY_URL=

# API key for external access (leave empty to disable auth)
API_KEY=

# Background upgrader interval in seconds (default: 4 hours)
UPGRADE_INTERVAL=14400

# ─── AI Recommendations (optional) ──────────────────────────────
# Provider: openai, deepseek, claude, openrouter
LLM_PROVIDER=
LLM_API_KEY=
# Override default model (optional). Defaults per provider:
#   openai: gpt-4o-mini, deepseek: deepseek-chat,
#   claude: claude-sonnet-4-20250514, openrouter: deepseek/deepseek-chat
LLM_MODEL=

# Navidrome credentials (for playlist creation)
NAVIDROME_URL=http://navidrome:4533
NAVIDROME_USER=
NAVIDROME_PASSWORD=

# Auto-recommendation interval in seconds (0 = disabled, manual only)
RECOMMEND_INTERVAL=0
# Hours before unrated recommendations are deleted (default: 24)
RECOMMEND_CLEANUP_HOURS=24

# ─── Client ──────────────────────────────────────────────────────
# Server URL for the CLI client
MUSIC_API_URL=http://your-server-ip:8844
